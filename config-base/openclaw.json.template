  "agents": {
    "defaults": {
      "model": {
        "primary": "deepseek/deepseek-chat",
        "fallbacks": [
          "bailian/qwen3.5-plus",
          "bailian/kimi-k2.5",
          "deepseek/deepseek-reasoner",
          "bailian/qwen3-max-2026-01-23"
        ]
      },
      "bootstrapMaxChars": 5000,
      "compaction": {
        "mode": "safeguard",
        "memoryFlush": {
          "prompt": "1) 将活跃任务/决策/关键细节更新到 SESSION-STATE.md；2) 将重要信息写入 memory/YYYY-MM-DD.md；3) 使用智能摘要：提取关键实体、关系、决策点；4) 丢弃重复信息、过时数据、无关细节；5) 如上下文>50%，创建 memory/working-buffer.md 摘要。如果没有需要保存的内容，回复 NO_REPLY。"
        }
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "idle",
      "idleMinutes": 10080
    },
    "resetByType": {
      "direct": {
        "mode": "idle",
        "idleMinutes": 180
      },
      "dm": {
        "mode": "idle",
        "idleMinutes": 180
      }
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "appId": "__APP_ID__",
      "appSecret": {
        "source": "env",
        "id": "FEISHU_APP_SECRET"
      },
      "domain": "feishu",
      "groupPolicy": "allowlist",
      "groupAllowFrom": [],
      "topicSessionMode": "disabled",
      "responseWatchdogSec": 15,
      "dmPolicy": "allowlist",
      "allowFrom": [],
      "sessionDispatchConcurrency": 5,
      "docEditorOpenIds": []
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "__AUTO_GENERATE__"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.clip",
        "calendar.add",
        "contacts.add",
        "reminders.add"
      ]
    }
  },
  "plugins": {
    "allow": [
      "lossless-claw",
      "feishu_local",
      "feishu"
    ],
    "slots": {
      "contextEngine": "lossless-claw"
    },
    "entries": {
      "lossless-claw": {
        "enabled": true,
        "config": {
          "freshTailCount": 16,
          "contextThreshold": 0.65,
          "incrementalMaxDepth": -1,
          "summaryModel": "deepseek/deepseek-chat"
        }
      },
      "feishu": {
        "enabled": false
      },
      "feishu_local": {
        "enabled": true
      }
    }
  }
}
