# ============================================
# xyvaClaw 密钥配置模板
# 复制此文件为 .env 并填写你的密钥
# ============================================

# ---- AI 模型 API Key ----

# DeepSeek API Key（推荐，性价比高）
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# 百炼/通义千问 API Key（支持 qwen、kimi、glm、minimax 等模型）
# 获取地址: https://bailian.console.aliyun.com/
BAILIAN_API_KEY=

# ---- 消息通道 ----

# 飞书应用凭证（如果使用飞书通道）
# 获取地址: https://open.feishu.cn/ -> 你的应用 -> 凭证与基础信息
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 钉钉应用凭证（如果使用钉钉通道，预留）
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=

# ---- 可选技能密钥 ----

# Tushare Token（量化选股，选填）
# 获取地址: https://tushare.pro/
TUSHARE_TOKEN=

# 小红书 Cookie（小红书自动化，选填，会过期）
XHS_COOKIE=

# ---- 系统设置 ----

# Gateway 端口（默认 18789）
GATEWAY_PORT=18789

# Gateway Token（留空自动生成）
GATEWAY_TOKEN=

# AI 助手名称
ASSISTANT_NAME=
